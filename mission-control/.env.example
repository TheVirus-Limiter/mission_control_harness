# ============================================================================
# Mission Control — environment variables
# Copy this file to `.env` and fill in what you have. EVERYTHING IS OPTIONAL.
# With no keys at all, the harness runs fully on deterministic mock workers and
# posting stays in DRY_RUN (no real network calls are ever made).
# ============================================================================

# --- LLM providers (optional; only needed for `python harness.py --real`) ----
# Anthropic (Claude) — used by ClaudeWorker and the Anthropic judge.
ANTHROPIC_API_KEY=

# OpenAI — used by the OpenAI-compatible worker and the OpenAI judge.
OPENAI_API_KEY=

# NVIDIA NIM — served through the OpenAI-compatible client by pointing
# base_url at https://integrate.api.nvidia.com/v1
# ONE key activates the ENTIRE NIM bunch declared in models/judges.py
# (DeepSeek, Mistral/Mixtral, Qwen, Gemma, Phi, Llama, Nemotron, ...). Add more
# from https://build.nvidia.com/explore/discover by editing NIM_CATALOG.
NVIDIA_API_KEY=

# Optional: cap how many judges run (cost control). e.g. MAX_JUDGES=4
MAX_JUDGES=

# Optional: run LOCAL judges via Ollama (a local runtime, OpenAI-compatible).
# Setting this activates the OLLAMA_CATALOG judges in models/judges.py.
# OLLAMA_HOST=http://localhost:11434/v1
OLLAMA_HOST=

# --- Safety switch -----------------------------------------------------------
# Posting is DRY_RUN by default. A REAL post to X requires ALL of:
#   (1) DRY_RUN explicitly set to "0"/"false",
#   (2) the X credentials below present, AND
#   (3) a recorded human approval at Gate 3.
# Leave this as 1 unless you genuinely intend to post.
DRY_RUN=1

# --- X (Twitter) API v2 credentials (optional) -------------------------------
# Absence of any of these simply keeps the system in dry-run forever.
# OAuth 1.0a user-context credentials for POST /2/tweets:
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
# Or an OAuth2 user-context bearer token, if you use that flow instead:
X_BEARER_TOKEN=
