# ============================================================================
# Mission Control — environment variables
# Copy this file to `.env` and fill in what you have. EVERYTHING IS OPTIONAL.
# With no keys at all the harness runs on deterministic mock workers, and
# posting stays in DRY_RUN (no real network calls are ever made).
# ============================================================================

# --- LLM providers (optional; needed for --real and the --preset models) ----
# Anthropic (Claude) — ClaudeWorker + the Anthropic judge/preset.
ANTHROPIC_API_KEY=

# OpenAI — the OpenAI-compatible worker + the OpenAI judge/preset.
OPENAI_API_KEY=

# Tavily web search (free tier at https://tavily.com) — when set, the researcher
# pulls REAL sourced facts from the web instead of relying on a model's memory.
TAVILY_API_KEY=

# NVIDIA NIM — served through the OpenAI-compatible client (base_url
# https://integrate.api.nvidia.com/v1). ONE key activates the whole NVIDIA
# barrage in models/judges.py (Llama 3.1/3.3/4, Mixtral, Phi-4, gpt-oss, Qwen3,
# Nemotron, GLM, Mistral Large). See: python harness.py --list-presets
NVIDIA_API_KEY=

# Optional: cap how many judges run, to bound real-model cost (default 6).
MAX_JUDGES=

# Optional: run LOCAL judges via Ollama (a local runtime, OpenAI-compatible).
# OLLAMA_HOST=http://localhost:11434/v1
OLLAMA_HOST=

# --- Safety switch -----------------------------------------------------------
# Posting is DRY_RUN by default. A REAL post to X needs ALL of:
#   (1) DRY_RUN explicitly "0"/"false",
#   (2) the X OAuth1 credentials below present, AND
#   (3) an INTERACTIVE human approval at Gate 3 (NOT --yes / not the auto path).
# Leave this 1 unless you genuinely intend to post.
DRY_RUN=1

# --- X (Twitter) API v2 credentials (optional) -------------------------------
# Posting to /2/tweets needs OAuth 1.0a USER-CONTEXT — these four. A Bearer
# Token / OAuth2 Client ID cannot post. Generate the Access Token + Secret AFTER
# setting the app to Read+Write. Verify with: python harness.py --verify-x
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
# Optional OAuth2 / app-only bearer (NOT used for posting; read-only):
X_BEARER_TOKEN=
